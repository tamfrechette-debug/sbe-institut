---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" currentPath="/contact" description="Coordonnées de SBÉ Institut Dermo-Capillaire. Adresse, téléphone, courriel et heures d'ouverture.">

  <!-- HERO -->
  <section class="hero" style="min-height: 40vh;">
    <div class="hero-content">
      <span class="eyebrow">Contact</span>
      <h1>Nous joindre</h1>
      <p class="tagline">Pour toute question ou information complémentaire</p>
    </div>
  </section>

  <!-- COORDONNÉES -->
  <section>
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h4>Adresse</h4>
          <p>95 rue des Pins<br/>Magog, QC&nbsp;&nbsp;J1X 2H6</p>
        </div>

        <div class="contact-info">
          <h4>Téléphone</h4>
          <p><a href="tel:+18193426941" style="color: var(--noir);">(819) 342-6941</a></p>
        </div>

        <div class="contact-info">
          <h4>Courriel</h4>
          <p><a href="mailto:contact@sbeinstitut.com" style="color: var(--noir);">contact@sbeinstitut.com</a></p>
        </div>

        <div class="contact-info">
          <h4>Heures d'ouverture</h4>
          <p style="font-size: 0.95rem;">
            <span style="display: block;">Dimanche : Fermé</span>
            <span style="display: block;">Lundi : Fermé</span>
            <span style="display: block;">Mardi : 10 h – 17 h</span>
            <span style="display: block;">Mercredi : 12 h – 20 h</span>
            <span style="display: block;">Jeudi : 10 h – 20 h</span>
            <span style="display: block;">Vendredi : 10 h – 16 h</span>
            <span style="display: block;">Samedi : 10 h – 15 h</span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-creme">
    <div class="container-narrow" style="text-align: center;">
      <h2>Prendre rendez-vous</h2>
      <p style="margin: 1rem 0 2rem;">
        La façon la plus rapide de réserver votre soin : en ligne, à toute heure.
      </p>
      <a href="/reservation" class="btn btn-primary">Réserver en ligne</a>
    </div>
  </section>
</BaseLayout>
