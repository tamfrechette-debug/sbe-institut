---
import BaseLayout from '../layouts/BaseLayout.astro';

// Hauteur du widget Square calculée à partir du nombre de services.
// Quand tu ajoutes/retires un service dans Square, mets à jour ce nombre.
const NB_SOINS_SQUARE = 17;
const hauteurSquare = Math.max(900, 250 + NB_SOINS_SQUARE * 100);
---

<BaseLayout title="Réservation" currentPath="/reservation" description="Réservez votre soin en ligne chez SBÉ Institut Dermo-Capillaire. Disponible 24h/24, 7 jours sur 7.">

  <!-- HERO -->
  <section class="hero" style="min-height: 40vh;">
    <div class="hero-content">
      <span class="eyebrow">Réservation</span>
      <h1>Prendre rendez-vous</h1>
      <p class="tagline">Réservez en quelques clics, à tout moment</p>
    </div>
  </section>

  <!-- WIDGET SQUARE -->
  <section style="padding-top: 0;">
    <div class="container">
      <div class="info-banner" style="max-width: 1100px; margin: 0 auto var(--espace-md);">
        <p>
          <strong>À noter :</strong> les soins Headspa sont disponibles
          uniquement les <strong>mercredis</strong> et <strong>vendredis</strong>.
        </p>
      </div>
      <div class="square-embed" id="square-embed" style={`--square-height: ${hauteurSquare}px;`}>
        <script is:inline src="https://square.site/appointments/buyer/widget/22zy2471w6xot4/LJ1FQ816N54Y2.js"></script>
        <noscript>
          <div style="text-align: center; padding: 2rem 1rem;">
            <p>
              Pour réserver, veuillez activer JavaScript dans votre navigateur,
              ou nous contacter directement au
              <a href="tel:+18193426941">(819) 342-6941</a>.
            </p>
          </div>
        </noscript>
      </div>
    </div>
  </section>

  <!-- POLITIQUE D'ANNULATION -->
  <section class="section-creme">
    <div class="container-narrow">
      <span class="eyebrow">À savoir avant de réserver</span>
      <h2>Politique d'annulation</h2>
      <div class="divider" style="margin-left: 0;"></div>

      <p style="font-size: 1.05rem;">
        Chaque rendez-vous vous est entièrement réservé, c'est pourquoi une
        carte de crédit est requise pour le confirmer. Vous pouvez annuler ou
        modifier sans frais jusqu'à 24 h avant votre visite. Passé ce délai,
        des frais de 50 % s'appliquent.
        Un retard de plus de 15 minutes est considéré comme une annulation
        tardive.
      </p>
      <p style="margin-top: 1rem; font-style: italic;">
        Merci de votre compréhension — nous avons hâte de vous accueillir.
      </p>

      <div style="margin-top: 2rem;">
        <a href="/politiques" class="btn btn-outline">Voir toutes les politiques</a>
      </div>
    </div>
  </section>

  <!-- CONTRE-INDICATIONS -->
  <section>
    <div class="container-narrow">
      <span class="eyebrow">Important</span>
      <h2>Contre-indications</h2>
      <div class="divider" style="margin-left: 0;"></div>

      <p>
        Avant de réserver, veuillez vérifier qu'aucune des conditions
        suivantes ne vous concerne :
      </p>
      <ul style="margin: 1.5rem 0 1.5rem 2rem; color: var(--gris-texte);">
        <li style="margin-bottom: 0.5rem;">Cancer actif ou récent</li>
        <li style="margin-bottom: 0.5rem;">Infections cutanées actives</li>
        <li style="margin-bottom: 0.5rem;">Eczéma, psoriasis ou rosacée en phase active</li>
        <li style="margin-bottom: 0.5rem;">Peau irritée, brûlée ou récemment traitée</li>
        <li style="margin-bottom: 0.5rem;">Troubles de la cicatrisation</li>
        <li style="margin-bottom: 0.5rem;">Prise de médicaments anticoagulants</li>
        <li style="margin-bottom: 0.5rem;">Grossesse</li>
        <li style="margin-bottom: 0.5rem;">Maladies auto-immunes non stabilisées</li>
        <li style="margin-bottom: 0.5rem;">Diabète mal contrôlé</li>
        <li style="margin-bottom: 0.5rem;">Allergies aux produits utilisés</li>
      </ul>
      <p style="font-size: 0.95rem; font-style: italic;">
        En cas de doute, n'hésitez pas à nous contacter avant votre rendez-vous.
        Une contre-indication identifiée à votre arrivée n'entraîne aucun frais.
      </p>
    </div>
  </section>
</BaseLayout>
