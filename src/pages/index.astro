---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Accueil" currentPath="/">
  <!-- HERO -->
  <section class="hero">
    <div class="hero-content">
      <span class="eyebrow">SBÉ</span>
      <h1>L'expertise au service<br/>de votre bien-être</h1>
      <p class="tagline">Science, écoute et solutions personnalisées</p>
      <p class="description">
        Un espace dédié à la santé et à la beauté du cuir chevelu et de la peau,
        où expertise et bien-être se rencontrent pour des résultats durables.
      </p>
      <div style="margin-top: 2rem;">
        <a href="/reservation" class="btn btn-primary">Prendre rendez-vous</a>
      </div>
    </div>
  </section>

  <!-- APPROCHE -->
  <section class="section-creme">
    <div class="container-narrow" style="text-align: center;">
      <span class="eyebrow">Notre approche</span>
      <h2>Une vision globale, des résultats durables</h2>
      <div class="divider"></div>
      <p style="font-size: 1.1rem;">
        Spécialisé dans les soins du visage et les traitements capillaires,
        SBÉ Institut propose une approche globale visant à traiter les problématiques
        à la source tout en valorisant le bien-être et la confiance en soi.
      </p>
      <p style="font-size: 1.1rem;">
        Grâce à une analyse approfondie et un accompagnement sur mesure, chaque
        protocole est adapté à votre profil pour des résultats visibles et harmonieux.
      </p>
    </div>
  </section>

  <!-- VALEURS -->
  <section>
    <div class="container">
      <div style="text-align: center; margin-bottom: 3rem;">
        <span class="eyebrow">Nos engagements</span>
        <h2>L'institut en quelques mots</h2>
        <div class="divider"></div>
      </div>

      <div class="values-grid">
        <div class="value-item">
          <span class="number">01</span>
          <h4>Expertise scientifique</h4>
          <p>Une formation pointue en trichologie et en médico-esthétique pour comprendre vos besoins en profondeur.</p>
        </div>
        <div class="value-item">
          <span class="number">02</span>
          <h4>Approche personnalisée</h4>
          <p>Chaque protocole est conçu sur mesure après une analyse complète de votre cuir chevelu ou de votre peau.</p>
        </div>
        <div class="value-item">
          <span class="number">03</span>
          <h4>Bienveillance & écoute</h4>
          <p>Un accompagnement éducatif qui vous guide vers une meilleure compréhension de vos besoins.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DÉPARTEMENTS -->
  <section class="section-creme">
    <div class="container">
      <div style="text-align: center; margin-bottom: 3rem;">
        <span class="eyebrow">Nos départements</span>
        <h2>Trois pôles d'expertise</h2>
        <div class="divider"></div>
        <p style="font-size: 1.05rem; max-width: 620px; margin: 1.5rem auto 0;">
          Une approche complète qui réunit science capillaire, esthétique
          médicale et bien-être sensoriel.
        </p>
      </div>

      <div class="departments-grid">
        <div class="department-card">
          <div class="department-icon">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M 16 42 Q 16 20, 32 14 Q 48 20, 48 42"/>
              <line x1="22" y1="42" x2="22" y2="50"/>
              <line x1="28" y1="42" x2="28" y2="52"/>
              <line x1="32" y1="42" x2="32" y2="54"/>
              <line x1="36" y1="42" x2="36" y2="52"/>
              <line x1="42" y1="42" x2="42" y2="50"/>
            </svg>
          </div>
          <h3>Trichologie & soins capillaires</h3>
          <p>
            Diagnostic, traitement et prévention des problématiques du cuir
            chevelu — chute de cheveux, pellicules, déséquilibres séborrhéiques.
          </p>
          <a href="/services" class="department-link">Découvrir →</a>
        </div>

        <div class="department-card">
          <div class="department-icon">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M 32 12 C 22 12, 16 22, 16 36 C 16 48, 24 54, 32 54 C 40 54, 48 48, 48 36 C 48 22, 42 12, 32 12 Z"/>
              <path d="M 24 32 Q 32 38, 40 32"/>
              <circle cx="26" cy="28" r="0.8" fill="currentColor"/>
              <circle cx="38" cy="28" r="0.8" fill="currentColor"/>
            </svg>
          </div>
          <h3>Esthétique avancée</h3>
          <p>
            Microneedling, peelings chimiques et soins du visage personnalisés
            pour révéler l'éclat naturel et la santé de votre peau.
          </p>
          <a href="/services" class="department-link">Découvrir →</a>
        </div>

        <div class="department-card">
          <div class="department-icon">
            <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="32" cy="32" r="14"/>
              <path d="M 6 28 Q 11 23, 16 28"/>
              <path d="M 6 36 Q 11 31, 16 36"/>
              <path d="M 48 28 Q 53 23, 58 28"/>
              <path d="M 48 36 Q 53 31, 58 36"/>
            </svg>
          </div>
          <h3>Headspa</h3>
          <p>
            Rituels sensoriels combinant massage crânien, soin capillaire et
            détente profonde. <em>Disponible mercredi et vendredi uniquement.</em>
          </p>
          <a href="/services" class="department-link">Découvrir →</a>
        </div>
      </div>

      <div style="text-align: center; margin-top: 3rem;">
        <a href="/services" class="btn btn-outline">Découvrir tous les soins</a>
      </div>
    </div>
  </section>

  <!-- CITATION -->
  <section>
    <div class="container">
      <div class="quote">
        Une approche professionnelle, bienveillante et éducative,
        pour des résultats visibles et harmonieux.
      </div>
    </div>
  </section>

  <!-- CTA RÉSERVATION -->
  <section class="section-emeraude">
    <div class="container-narrow" style="text-align: center;">
      <span class="eyebrow eyebrow-light">Prendre soin de soi</span>
      <h2>Prêt(e) à commencer votre parcours?</h2>
      <p style="font-size: 1.1rem; margin-bottom: 2rem;">
        Réservez votre consultation ou votre soin en ligne, en quelques clics.
      </p>
      <a href="/reservation" class="btn btn-outline-light">Prendre rendez-vous</a>
    </div>
  </section>
</BaseLayout>
